{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "noEmit": true,
        "allowUmdGlobalAccess": true,
        "allowImportingTsExtensions": true,
        "rootDirs": ["src", "plugins", "tests"],
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@/*": ["./src/*"],
            "@tests/*": ["./tests/*"],
        },
        "types": ["vitest/globals"],
    }
}
