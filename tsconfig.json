{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "nodenext",
        "importHelpers": true,
        "isolatedModules": true,
        "noEmit": true,
        "allowUmdGlobalAccess": true,
        "allowImportingTsExtensions": true,
        "rootDir": "src",
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vitest/globals"],
    }
}
