{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "noEmit": true,
        "allowUmdGlobalAccess": true,
        "allowImportingTsExtensions": true,
        "rootDirs": ["src", "plugins"],
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vitest/globals"],
    }
}
