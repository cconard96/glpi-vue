{
    "name": "glpi-vue",
    "version": "0.0.0",
    "private": true,
    "description": "A Vue-based frontend for GLPI",
    "type": "module",
    "scripts": {
        "prepare": ".hooks/prepare.sh",
        "dev": "vite --force",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest",
        "coverage": "vitest run --coverage",
        "postinstall": "patch-package",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt --check",
        "fmt:fix": "oxfmt",
        "report-i18n": "vue-i18n-extract report --ci --vueFiles './src/**/*.?(ts|vue)' --languageFiles './locales/*.json'",
        "extract-i18n": "vue-i18n-extract report --add --vueFiles './src/**/*.?(ts|vue)' --languageFiles './locales/*.json'"
    },
    "dependencies": {
        "@apollo/client": "^4.2.0",
        "@primeuix/themes": "^1.2.5",
        "@primevue/forms": "^4.5.5",
        "@vueuse/core": "^14.1.0",
        "@vueuse/integrations": "^14.3.0",
        "axios": "^1.16.1",
        "chart.js": "^4.5.1",
        "drauu": "^0.4.3",
        "fuse.js": "^7.3.0",
        "graphql": "^16.14.0",
        "graphql-tag": "^2.12.6",
        "gridstack": "^12.6.0",
        "patch-package": "^8.0.1",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "primelocale": "^2.3.2",
        "primevue": "^4.5.5",
        "quill": "^2.0.3",
        "tailwindcss-primeui": "^0.6.1",
        "vue": "3.5.30",
        "vue-dompurify-html": "^5.3.0",
        "vue-i18n": "^11.4.4",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@intlify/eslint-plugin-vue-i18n": "^4.4.0",
        "@tailwindcss/vite": "^4.3.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/browser-playwright": "^4.0.4",
        "@vitest/coverage-v8": "^4.0.4",
        "@vue/test-utils": "^2.4.10",
        "globals": "^16.5.0",
        "mock-apollo-client": "^2.0.0",
        "openapi-typescript": "^7.13.0",
        "oxfmt": "^0.33.0",
        "oxlint": "^1.66.0",
        "playwright": "^1.60.0",
        "tailwindcss": "^4.2.4",
        "typescript": "^5.9.3",
        "vite": "^8.0.14",
        "vite-plugin-pwa": "^1.3.0",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vitest": "^4.0.4",
        "vitest-browser-vue": "^2.1.0",
        "vue-i18n-extract": "^2.0.7",
        "vue3-snapshot-serializer": "^2.13.2"
    },
    "overrides": {
        "vite-plugin-pwa": {
            "vite": "$vite"
        }
    }
}
